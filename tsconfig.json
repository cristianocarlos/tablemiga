{
    "compilerOptions": {
        "declaration": true,
        "emitDeclarationOnly": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "./dist",
        "paths": {
            "@/*": ["./src/*"]
        },
        "rootDir": "./src",
        "strict": true,
        "skipLibCheck": true,
        "target": "ESNext"
    }
}
